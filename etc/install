#!/bin/bash

# Usage:
# curl -fsSL https://raw.githubusercontent.com/dabsdamoon/my-little-dotfiles/main/etc/install | bash

cat <<EOF
   my-little-dotfiles
   AI-agent-optimized dotfiles (based on wookayin/dotfiles)
   https://github.com/dabsdamoon/my-little-dotfiles
EOF

# Check minimal dependencies
if ! command -v git &> /dev/null; then echo "ERROR: git not found. (Try $APT install git)"; exit; fi
if ! command -v curl &> /dev/null; then echo "ERROR: curl not found. (Try $APT install curl)"; exit; fi
if ! command -v wget &> /dev/null; then echo "ERROR: wget not found. (Try $APT install wget)"; exit; fi

if which python3 > /dev/null; then
    PYTHON="python3"
else
    PYTHON="python"
fi
if ! command -v $PYTHON &> /dev/null; then echo "ERROR: python not found. (Try $APT install python3-pip)"; exit; fi

_version_check() {
    curver="$1"; targetver="$2";
    [ "$targetver" = "$(echo -e "$curver\n$targetver" | sort -V | head -n1)" ]
}

if _version_check "$(git --version | cut -d' ' -f3)" "2.8"; then
    GIT_FLAGS="-j8"
fi

GIT_REPO="https://github.com/dabsdamoon/my-little-dotfiles.git"

set -x
set -e

# ============================================================================

# Install neovim from pre-built binary (fast, no compilation)
_install_neovim_binary() {
    local nvim_url=""
    local os="$(uname)"
    local arch="$(uname -m)"

    if [[ "$os" == "Darwin" ]]; then
        if [[ "$arch" == "arm64" ]]; then
            nvim_url="https://github.com/neovim/neovim/releases/latest/download/nvim-macos-arm64.tar.gz"
        else
            nvim_url="https://github.com/neovim/neovim/releases/latest/download/nvim-macos-x86_64.tar.gz"
        fi
    elif [[ "$os" == "Linux" ]]; then
        nvim_url="https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz"
    fi

    if [[ -z "$nvim_url" ]]; then
        echo "Cannot detect platform for neovim binary. Skipping."
        return 1
    fi

    echo "Installing neovim from pre-built binary..."
    mkdir -p "$HOME/.local/bin"
    local tmpfile="$(mktemp)"
    curl -fsSL -o "$tmpfile" "$nvim_url"
    tar xzf "$tmpfile" -C /tmp
    rm -rf "$HOME/.local/nvim"
    mv /tmp/nvim-* "$HOME/.local/nvim"
    ln -sf "$HOME/.local/nvim/bin/nvim" "$HOME/.local/bin/nvim"
    rm -f "$tmpfile"
    echo "neovim: installed ($("$HOME/.local/bin/nvim" --version | head -1))"
}

# Install essential tools
_install_essentials() {
    if [[ "$(uname)" == "Darwin" ]]; then
        # macOS: use Homebrew for tmux and node
        if ! command -v brew &> /dev/null; then
            echo "Installing Homebrew..."
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        fi
        echo "Installing essential packages..."
        for pkg in tmux node; do
            if ! brew list "$pkg" &>/dev/null; then
                brew install "$pkg" || true
            else
                echo "$pkg: already installed"
            fi
        done

        # Neovim: prefer pre-built binary (brew compiles from source on older macOS)
        if ! command -v nvim &>/dev/null; then
            _install_neovim_binary || brew install neovim || true
        else
            echo "neovim: already installed"
        fi
    elif [[ "$(uname)" == "Linux" ]]; then
        # Linux: tmux and node via apt, neovim via binary
        if command -v apt-get &> /dev/null; then
            echo "Installing essential packages..."
            sudo apt-get update -qq
            sudo apt-get install -y -qq tmux nodejs npm 2>/dev/null || true
        fi

        if ! command -v nvim &>/dev/null; then
            _install_neovim_binary || true
        else
            echo "neovim: already installed"
        fi
    fi
}

_install_essentials

cd ~

git clone --recursive ${GIT_FLAGS} -b main ${GIT_REPO} ~/.dotfiles
cd ~/.dotfiles && $PYTHON install.py

echo "All Done!"
