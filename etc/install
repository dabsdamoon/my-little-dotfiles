#!/bin/bash

# Usage:
# curl -fsSL https://raw.githubusercontent.com/dabsdamoon/my-little-dotfiles/main/etc/install | bash

cat <<EOF
   my-little-dotfiles
   AI-agent-optimized dotfiles (based on wookayin/dotfiles)
   https://github.com/dabsdamoon/my-little-dotfiles
EOF

# Check minimal dependencies
if ! command -v git &> /dev/null; then echo "ERROR: git not found. (Try $APT install git)"; exit; fi
if ! command -v curl &> /dev/null; then echo "ERROR: curl not found. (Try $APT install curl)"; exit; fi
if ! command -v wget &> /dev/null; then echo "ERROR: wget not found. (Try $APT install wget)"; exit; fi

if which python3 > /dev/null; then
    PYTHON="python3"
else
    PYTHON="python"
fi
if ! command -v $PYTHON &> /dev/null; then echo "ERROR: python not found. (Try $APT install python3-pip)"; exit; fi

_version_check() {
    curver="$1"; targetver="$2";
    [ "$targetver" = "$(echo -e "$curver\n$targetver" | sort -V | head -n1)" ]
}

if _version_check "$(git --version | cut -d' ' -f3)" "2.8"; then
    GIT_FLAGS="-j8"
fi

GIT_REPO="https://github.com/dabsdamoon/my-little-dotfiles.git"

set -x
set -e

# ============================================================================

# Install a tool from a pre-built binary tarball into ~/.local/
# Usage: _install_binary <name> <url> <binary_path_inside_tarball>
_install_binary() {
    local name="$1" url="$2" bin_path="$3"
    echo "Installing $name from pre-built binary..."
    mkdir -p "$HOME/.local/bin"
    local tmpfile="$(mktemp)"
    curl -fsSL -o "$tmpfile" "$url"
    tar xzf "$tmpfile" -C /tmp
    rm -rf "$HOME/.local/$name"
    mv /tmp/${name}* "$HOME/.local/$name" 2>/dev/null || mv /tmp/${name}* "$HOME/.local/$name" 2>/dev/null
    ln -sf "$HOME/.local/$name/$bin_path" "$HOME/.local/bin/$name"
    rm -f "$tmpfile"
    echo "$name: installed ($("$HOME/.local/bin/$name" --version 2>/dev/null | head -1))"
}

_install_neovim() {
    local os="$(uname)" arch="$(uname -m)"
    if [[ "$os" == "Darwin" && "$arch" == "arm64" ]]; then
        _install_binary nvim "https://github.com/neovim/neovim/releases/latest/download/nvim-macos-arm64.tar.gz" "bin/nvim"
    elif [[ "$os" == "Darwin" ]]; then
        _install_binary nvim "https://github.com/neovim/neovim/releases/latest/download/nvim-macos-x86_64.tar.gz" "bin/nvim"
    elif [[ "$os" == "Linux" ]]; then
        _install_binary nvim "https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz" "bin/nvim"
    fi
}

_install_node() {
    local os="$(uname)" arch="$(uname -m)"
    # Use Node 22 LTS
    local node_ver="v22.16.0"
    if [[ "$os" == "Darwin" && "$arch" == "arm64" ]]; then
        _install_binary node "https://nodejs.org/dist/${node_ver}/node-${node_ver}-darwin-arm64.tar.gz" "bin/node"
    elif [[ "$os" == "Darwin" ]]; then
        _install_binary node "https://nodejs.org/dist/${node_ver}/node-${node_ver}-darwin-x64.tar.gz" "bin/node"
    elif [[ "$os" == "Linux" ]]; then
        _install_binary node "https://nodejs.org/dist/${node_ver}/node-${node_ver}-linux-x64.tar.gz" "bin/node"
    fi
    # Symlink npm and npx too
    if [[ -d "$HOME/.local/node" ]]; then
        ln -sf "$HOME/.local/node/bin/npm" "$HOME/.local/bin/npm"
        ln -sf "$HOME/.local/node/bin/npx" "$HOME/.local/bin/npx"
    fi
}

# Install essential tools
_install_essentials() {
    mkdir -p "$HOME/.local/bin"
    # Ensure common bin paths are in PATH (curl|bash may have minimal PATH)
    export PATH="$HOME/.local/bin:/usr/local/bin:/opt/homebrew/bin:$PATH"

    echo "Installing essential packages..."

    # Neovim: always use pre-built binary (fast, no compilation)
    if ! command -v nvim &>/dev/null; then
        _install_neovim || true
    else
        echo "neovim: already installed ($(nvim --version | head -1))"
    fi

    # Node: always use pre-built binary (avoids brew compiling python as dependency)
    if ! command -v node &>/dev/null; then
        _install_node || true
    else
        echo "node: already installed ($(node --version))"
    fi

    # Tmux
    if ! command -v tmux &>/dev/null; then
        if [[ "$(uname)" == "Linux" ]]; then
            # Linux: use AppImage (pre-built, no compilation)
            echo "Installing tmux from AppImage..."
            mkdir -p "$HOME/.local/bin"
            local latest_url=$(curl -fsSL https://api.github.com/repos/nelsonenzo/tmux-appimage/releases/latest \
                | grep "browser_download_url.*tmux.appimage" | head -1 | cut -d'"' -f4)
            if [[ -n "$latest_url" ]]; then
                curl -fsSL -o "$HOME/.local/bin/tmux" "$latest_url"
                chmod +x "$HOME/.local/bin/tmux"
                echo "tmux: installed ($("$HOME/.local/bin/tmux" -V))"
            else
                # Fallback to apt
                if command -v apt-get &>/dev/null; then
                    sudo apt-get update -qq
                    sudo apt-get install -y -qq tmux 2>/dev/null || true
                fi
            fi
        elif [[ "$(uname)" == "Darwin" ]]; then
            # macOS: compile from source (small, fast -- unlike cmake/python)
            echo "Installing tmux from source..."
            local tmux_ver="3.6a"
            local tmpdir="$(mktemp -d)"
            curl -fsSL "https://github.com/tmux/tmux/releases/download/${tmux_ver}/tmux-${tmux_ver}.tar.gz" | tar xz -C "$tmpdir"
            cd "$tmpdir/tmux-${tmux_ver}"
            ./configure --prefix="$HOME/.local" 2>/dev/null && make -j$(sysctl -n hw.ncpu) 2>/dev/null && make install 2>/dev/null
            cd - >/dev/null
            rm -rf "$tmpdir"
            if [[ -f "$HOME/.local/bin/tmux" ]]; then
                echo "tmux: installed ($("$HOME/.local/bin/tmux" -V))"
            else
                echo "tmux: source build failed. Install manually: brew install tmux"
            fi
        fi
    else
        echo "tmux: already installed ($(tmux -V))"
    fi

    # Claude Code Usage Monitor (cmonitor)
    if ! command -v cmonitor &>/dev/null && ! command -v claude-monitor &>/dev/null; then
        if command -v pip3 &>/dev/null; then
            echo "Installing claude-monitor (cmonitor)..."
            pip3 install --user claude-monitor 2>/dev/null || true
            # Symlink to ~/.local/bin so it's always in PATH
            local pip_bin="$(python3 -m site --user-base 2>/dev/null)/bin"
            if [[ -f "$pip_bin/cmonitor" ]]; then
                ln -sf "$pip_bin/cmonitor" "$HOME/.local/bin/cmonitor"
                ln -sf "$pip_bin/claude-monitor" "$HOME/.local/bin/claude-monitor"
            fi
        elif command -v uv &>/dev/null; then
            uv tool install claude-monitor 2>/dev/null || true
        fi
    else
        echo "cmonitor: already installed"
    fi
}

_install_essentials

cd ~

git clone --recursive ${GIT_FLAGS} -b main ${GIT_REPO} ~/.dotfiles
cd ~/.dotfiles && $PYTHON install.py

echo "All Done!"
