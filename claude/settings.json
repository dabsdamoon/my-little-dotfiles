{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "command": "grep -rn 'sk-ant-\\|sk-proj-\\|AKIA\\|ghp_\\|gho_\\|glpat-' /dev/stdin 2>/dev/null && echo 'WARNING: Possible credential detected in file edit' || true"
      }
    ]
  }
}
