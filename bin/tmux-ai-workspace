#!/bin/bash
#
# tmux-ai-workspace: Create an AI-assisted development layout.
#
# Layout:
# ┌──────────────────┬──────────────────┐
# │                  │                  │
# │  Claude Code     │  Shell (zsh)     │
# │                  │                  │
# │                  ├──────────────────┤
# │                  │  cmonitor        │
# │                  │  (token/cost)    │
# │                  │                  │
# └──────────────────┴──────────────────┘
#
# Usage: tmux-ai-workspace [session-name] [directory]

set -e

if ! command -v tmux &>/dev/null; then
  echo "tmux is not installed. Install it first:"
  echo "  brew install tmux    (macOS)"
  echo "  apt install tmux     (Ubuntu/Debian)"
  exit 1
fi

SESSION="${1:-ai-dev}"
DIR="${2:-$(pwd)}"

if tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "Session '$SESSION' already exists. Attaching..."
  tmux attach-session -t "$SESSION"
  exit 0
fi

# Create session with Claude Code pane (left)
tmux new-session -d -s "$SESSION" -c "$DIR"
tmux rename-window -t "$SESSION:1" "dev"

# Split right for shell (50%)
tmux split-window -h -t "$SESSION:1" -c "$DIR"

# Split bottom-right for cmonitor (50% of right side)
tmux split-window -v -t "$SESSION:1.2" -c "$DIR"

# Send commands to panes
# Pane 1: Claude Code
tmux send-keys -t "$SESSION:1.1" "claude" Enter
# Pane 2: clean shell (zsh)
# Pane 3: Claude Code usage monitor (falls back to clean shell)
# Detect plan from claude auth status, use CLAUDE_PLAN env var override
_detect_plan() {
  if [[ -n "$CLAUDE_PLAN" ]]; then
    echo "$CLAUDE_PLAN"
    return
  fi
  local sub_type=$(claude auth status --json 2>/dev/null | grep subscriptionType | cut -d'"' -f4)
  case "$sub_type" in
    pro)  echo "pro" ;;
    max)  echo "${CLAUDE_MAX_TIER:-max20}" ;;
    *)    echo "custom" ;;
  esac
}

if command -v cmonitor &>/dev/null; then
  PLAN=$(_detect_plan)
  tmux send-keys -t "$SESSION:1.3" "cmonitor --plan $PLAN" Enter
elif command -v claude-monitor &>/dev/null; then
  tmux send-keys -t "$SESSION:1.3" "claude-monitor" Enter
fi

# Focus on Claude Code pane
tmux select-pane -t "$SESSION:1.1"

# Attach
tmux attach-session -t "$SESSION"
