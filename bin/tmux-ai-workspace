#!/bin/bash
#
# tmux-ai-workspace: Create an AI-assisted development layout.
#
# Layout:
# ┌──────────────────┬──────────────────┐
# │                  │                  │
# │  AI Agent        │  Shell (zsh)     │
# │                  │                  │
# │                  ├──────────────────┤
# │                  │  Monitor         │
# │                  │  (agent aware)   │
# │                  │                  │
# └──────────────────┴──────────────────┘
#
# Usage: tmux-ai-workspace [--agent claude|codex] [session-name] [directory]

set -e

AGENT="claude"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)
      AGENT="${2:-}"
      shift 2
      ;;
    --agent=*)
      AGENT="${1#*=}"
      shift
      ;;
    -h|--help)
      echo "Usage: tmux-ai-workspace [--agent claude|codex] [session-name] [directory]"
      exit 0
      ;;
    *)
      break
      ;;
  esac
done

case "$AGENT" in
  claude|codex) ;;
  *)
    echo "Unsupported agent: $AGENT"
    echo "Supported values: claude, codex"
    exit 1
    ;;
esac

if ! command -v tmux &>/dev/null; then
  echo "tmux is not installed. Install it first:"
  echo "  brew install tmux    (macOS)"
  echo "  apt install tmux     (Ubuntu/Debian)"
  exit 1
fi

SESSION="${1:-${AGENT}-dev}"
DIR="${2:-$(pwd)}"

if tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "Session '$SESSION' already exists. Attaching..."
  tmux attach-session -t "$SESSION"
  exit 0
fi

# Create session with agent pane (left)
tmux new-session -d -s "$SESSION" -c "$DIR"
tmux rename-window -t "$SESSION:1" "dev"

# Force statusbar refresh: cold server start can race with the config's
# run-shell, leaving the "Loading ~/.tmux/statusbar.tmux..." placeholder.
if [ -x "$HOME/.tmux/statusbar.tmux" ]; then
  tmux run-shell "$HOME/.tmux/statusbar.tmux" 2>/dev/null || true
fi

# Split right for shell (50%)
tmux split-window -h -t "$SESSION:1" -c "$DIR"

# Split bottom-right for monitor (50% of right side)
tmux split-window -v -t "$SESSION:1.2" -c "$DIR"

# Send commands to panes
# Pane 1: AI agent
if [[ "$AGENT" == "codex" ]]; then
  if command -v codex &>/dev/null; then
    tmux send-keys -t "$SESSION:1.1" "codex" Enter
  else
    tmux send-keys -t "$SESSION:1.1" "echo 'codex is not installed'" Enter
  fi
else
  if command -v claude &>/dev/null; then
    tmux send-keys -t "$SESSION:1.1" "claude" Enter
  else
    tmux send-keys -t "$SESSION:1.1" "echo 'claude is not installed'" Enter
  fi
fi

# Pane 2: clean shell (zsh)
# Pane 3: agent-specific monitor (falls back to clean shell)
if [[ "$AGENT" == "codex" ]]; then
  if command -v codex-cmonitor &>/dev/null; then
    tmux send-keys -t "$SESSION:1.3" "codex-cmonitor --watch --trend-minutes 15" Enter
  else
    tmux send-keys -t "$SESSION:1.3" "echo 'codex-cmonitor is not installed'" Enter
  fi
else
  PLAN="${CLAUDE_PLAN:-}"
  if [[ -z "$PLAN" ]]; then
    SUB_TYPE=$(claude auth status --json 2>/dev/null | grep subscriptionType | cut -d'"' -f4 || true)
    case "$SUB_TYPE" in
      pro)  PLAN="pro" ;;
      max)  PLAN="${CLAUDE_MAX_TIER:-max20}" ;;
      *)    PLAN="custom" ;;
    esac
  fi

  if command -v cmonitor &>/dev/null; then
    tmux send-keys -t "$SESSION:1.3" "cmonitor --plan $PLAN" Enter
  elif command -v claude-monitor &>/dev/null; then
    tmux send-keys -t "$SESSION:1.3" "claude-monitor" Enter
  fi
fi

# Focus on agent pane
tmux select-pane -t "$SESSION:1.1"

# Attach
tmux attach-session -t "$SESSION"
