#!/bin/bash
#
# tmux-ai-workspace: Create an AI-assisted development layout.
#
# Layout:
# ┌──────────────────┬──────────────────┐
# │                  │                  │
# │   Shell (zsh)    │  Claude Code     │
# │                  │                  │
# │                  ├──────────────────┤
# │                  │  Memory Status   │
# │                  │                  │
# └──────────────────┴──────────────────┘
#
# Usage: tmux-ai-workspace [session-name] [directory]

set -e

if ! command -v tmux &>/dev/null; then
  echo "tmux is not installed. Install it first:"
  echo "  brew install tmux    (macOS)"
  echo "  apt install tmux     (Ubuntu/Debian)"
  exit 1
fi

SESSION="${1:-ai-dev}"
DIR="${2:-$(pwd)}"

if tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "Session '$SESSION' already exists. Attaching..."
  tmux attach-session -t "$SESSION"
  exit 0
fi

# Create session with shell pane (left)
tmux new-session -d -s "$SESSION" -c "$DIR"
tmux rename-window -t "$SESSION:1" "dev"

# Split right for Claude Code (50%)
tmux split-window -h -t "$SESSION:1" -c "$DIR"

# Split bottom-right for memory status (50% of right side)
tmux split-window -v -t "$SESSION:1.2" -c "$DIR"

# Send commands to panes
# Pane 1: clean shell (zsh)
# Pane 2: Claude Code
tmux send-keys -t "$SESSION:1.2" "claude" Enter
# Pane 3: Claude Code usage monitor (falls back to clean shell)
if command -v cmonitor &>/dev/null; then
  tmux send-keys -t "$SESSION:1.3" "cmonitor" Enter
elif command -v claude-monitor &>/dev/null; then
  tmux send-keys -t "$SESSION:1.3" "claude-monitor" Enter
fi

# Focus on shell pane
tmux select-pane -t "$SESSION:1.1"

# Attach
tmux attach-session -t "$SESSION"
